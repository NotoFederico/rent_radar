# Rent Radar — Variables de entorno
# Copiar como .env y completar con los valores reales.
# Sin espacios alrededor del =, sin comillas, sin comentarios inline.
# (Requerido por el parser de systemd EnvironmentFile.)

# ── Neon Postgres ─────────────────────────────────────────────────────────────
# Connection string del proyecto en neon.tech (incluye host, user, password, dbname)
NEON_DATABASE_URL=postgresql://neondb_owner:<password>@<host>.neon.tech/neondb?sslmode=require

# Password del usuario dbt (mismo que en NEON_DATABASE_URL, usado en ~/.dbt/profiles.yml)
DBT_PASSWORD=<password>

# ── Telegram ──────────────────────────────────────────────────────────────────
# Token del bot obtenido desde @BotFather
TELEGRAM_BOT_TOKEN=<token>

# ID(s) de chat donde se envían las notificaciones. Separar con coma para múltiples.
# Obtener el propio ID arrancando una conversación con @userinfobot
TELEGRAM_CHAT_ID=<chat_id>
